{
  "target_keywords": [],
  "extra_seeds": [],
  "tracking_query_keys": [
    "utm_source",
    "utm_medium",
    "utm_campaign",
    "utm_term",
    "utm_content",
    "utm_id",
    "spm",
    "from"
  ],
  "skip_dirs": [
    ".git",
    ".hg",
    ".svn",
    ".idea",
    ".vscode",
    ".claude",
    ".playwright-mcp",
    "__pycache__",
    "node_modules",
    "aspose-words-src",
    "aspose_classes",
    "dump",
    "remote_sites"
  ],
  "third_party_domains": [
    "hm.baidu.com",
    "bat.bing.com",
    "res.wx.qq.com",
    "api.geetest.com",
    "static.geetest.com",
    "cdn.jsdelivr.net",
    "cdnjs.cloudflare.com",
    "ajax.googleapis.com",
    "www.googletagmanager.com",
    "pingjs.qq.com",
    "imgcache.qq.com",
    "kefu.easemob.com",
    "cloudcache.tencent-cloud.com"
  ],
  "skip_extensions": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".ico",
    ".woff",
    ".woff2",
    ".svg",
    ".ttf",
    ".eot",
    ".css",
    ".js",
    ".map",
    ".pdf",
    ".mp3",
    ".mp4",
    ".webp",
    ".webm",
    ".avi",
    ".mov",
    ".html",
    ".htm"
  ],
  "api_prefixes": [
    "/api/",
    "/_api/",
    "/v1/",
    "/v2/",
    "/v3/",
    "/admin/",
    "/system/",
    "/security/",
    "/auth/",
    "/user/",
    "/users/",
    "/account/",
    "/accounts/",
    "/tenant/",
    "/org/",
    "/dept/",
    "/file/",
    "/files/",
    "/upload/",
    "/download/",
    "/export/",
    "/graphql",
    "/actuator/",
    "/swagger",
    "/openapi"
  ],
  "api_path_regexes": [
    "/[A-Z][a-zA-Z]*Service/",
    "/v[0-9]+/",
    "/(?:api|admin|system|security|auth|user|users|account|tenant|org|dept|file|files|upload|download|export)(?:/|$)",
    "/(?:graphql|actuator|swagger|openapi)(?:/|$)"
  ],
  "known_endpoints": [
    "/swagger-ui.html",
    "/swagger-resources",
    "/v2/api-docs",
    "/v3/api-docs",
    "/openapi.json",
    "/openapi.yaml",
    "/graphql",
    "/actuator",
    "/actuator/health",
    "/actuator/info",
    "/actuator/env",
    "/actuator/configprops",
    "/actuator/mappings"
  ],
  "special_keywords": [
    "swagger",
    "openapi",
    "graphql",
    "actuator"
  ],
  "garbage_substrings": [
    "/home/runner/",
    "node_modules",
    "_0x",
    "','",
    "\":\"",
    "':'",
    "addClass",
    "removeClass",
    "getAttribute",
    "ChunkLoadError",
    "CSS_CHUNK",
    "getElementsByTagName",
    "devicePixelRatio",
    "interceptors",
    "localStorage",
    "toString",
    "getBoundingClientRect",
    "querySelector",
    "createElement",
    "setAttribute"
  ],
  "extract_patterns": [
    {
      "name": "AXIOS_FETCH_LITERAL",
      "pattern": "(?:axios\\.(?:get|post|put|delete|patch|head|options|request)|fetch)\\s*\\(\\s*[\"'`]\\s*(?P<endpoint>/[a-zA-Z0-9_./\\-{}?=&:+%#@\\[\\];,]{2,400})\\s*[\"'`]",
      "kind": "relative",
      "confidence": "high"
    },
    {
      "name": "HTTP_ANNOTATION",
      "pattern": "@(?:GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|FormUrlEncoded|Multipart|Headers|Url)\\s*\\(\\s*[\"'`]\\s*(?P<endpoint>/[a-zA-Z0-9_./\\-{}?=&:+%#@\\[\\];,]{2,400})\\s*[\"'`]",
      "kind": "relative",
      "confidence": "high"
    },
    {
      "name": "URL_ATTR_RELATIVE",
      "pattern": "(?:url|api|baseURL|baseUrl|apiUrl|apiRoot|path|endpoint|href|src)\\s*[:=]\\s*[\"'`]\\s*(?P<endpoint>/[a-zA-Z0-9_./\\-{}?=&:+%#@\\[\\];,]{2,400})\\s*[\"'`]",
      "kind": "relative",
      "confidence": "medium"
    },
    {
      "name": "QUOTED_RELATIVE_PATH",
      "pattern": "[\"'`]\\s*(?P<endpoint>/(?:[a-zA-Z][a-zA-Z0-9_-]*/)*[a-zA-Z0-9_./\\-{}?=&:+%#@\\[\\];,]{2,300})\\s*[\"'`]",
      "kind": "relative",
      "confidence": "low"
    },
    {
      "name": "ABSOLUTE_URL",
      "pattern": "(?P<endpoint>https?://[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?\\.[a-z]{2,}(?::[0-9]+)?/[^\\s\"'`<>,;\\)\\]\\[{}\\\\]{1,500})",
      "kind": "absolute",
      "confidence": "medium"
    }
  ]
}
